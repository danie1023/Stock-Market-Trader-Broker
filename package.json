<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PrimeTrade</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-950 text-white min-h-screen">

  <div class="p-8 max-w-2xl mx-auto">
    <h1 class="text-4xl font-bold text-emerald-500 mb-8 text-center">PrimeTrade</h1>
    
    <div class="bg-zinc-900 rounded-3xl p-10">
      <h2 class="text-3xl mb-6">Stock Broker Dashboard</h2>
      <p class="text-5xl font-bold text-emerald-400 mb-2">$28,472.81</p>
      <p class="text-emerald-400 text-xl mb-10">+5.14% Today</p>
      
      <button onclick="alert('✅ Order Placed!')" 
              class="w-full bg-emerald-500 py-6 rounded-3xl text-xl font-semibold">
        BUY AAPL NOW
      </button>
    </div>
  </div>

</body>
</html>
